generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
  ABANDONED
}

enum ReportReason {
  FAKE
  INAPPROPRIATE
  SPAM
  COUNTERFEIT
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum NotificationType {
  NEW_MESSAGE
  NEW_ORDER
  ORDER_STATUS
  NEW_REVIEW
  SANCTION
  BAN
}

enum VoteValue {
  UP
  DOWN
}

enum SanctionType {
  WARNING
  SUSPENSION
  RESTRICTION_SELL
  RESTRICTION_MESSAGE
}

enum PayoutStatus {
  PENDING
  APPROVED
  PAID
  FAILED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  username      String    @unique
  name          String
  avatarUrl     String?
  location      String?
  rating        Float?
  reviewsCount  Int?      @default(0)
  role          Role      @default(USER)
  password      String?
  lastSeenAt    DateTime?
  isBanned      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  products        Product[]       @relation("ProductOwner")
  threads1        MessageThread[] @relation("ThreadsBuyer")
  threads2        MessageThread[] @relation("ThreadsSeller")
  messages        Message[]
  favorites       Favorite[]
  orders          Order[]         @relation("OrderBuyer")
  sales           Order[]         @relation("OrderSeller")
  accounts        Account[]
  sessions        Session[]
  reviewsGiven    Review[]        @relation("ReviewAuthor")
  reviewsReceived Review[]        @relation("ReviewTarget")
  reports         Report[]        @relation("ReportAuthor")
  notifications   Notification[]
  cart            Cart?
  votes           Vote[]
  sanctionsReceived Sanction[]    @relation("SanctionTarget")
  sanctionsGiven    Sanction[]    @relation("SanctionAdmin")
  bansReceived      Ban[]         @relation("BanTarget")
  bansGiven         Ban[]         @relation("BanAdmin")
  payouts           SellerPayout[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Category ─────────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
}

// ─── Product ──────────────────────────────────────────────────────────────────

model Product {
  id          String  @id
  title       String
  description String?
  brand       String?
  size        String?
  price       Decimal @db.Decimal(10, 2)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  categoryLegacy String? // ancien champ texte libre conservé pour migration
  condition   String?
  color       String?
  location    String?
  isActive    Boolean @default(true)

  imageUrl  String?
  imageUrls String[] @default([])

  ownerId String
  owner   User   @relation("ProductOwner", fields: [ownerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  favorites  Favorite[]
  threads    MessageThread[]
  orders     Order[]
  reports    Report[]
  cartItems  CartItem[]
  votes      Vote[]
  payouts    SellerPayout[]
}

// ─── Cart ─────────────────────────────────────────────────────────────────────

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  status    CartStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  unitPrice Decimal  @db.Decimal(10, 2)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
}

// ─── MessageThread / Message ──────────────────────────────────────────────────

model MessageThread {
  id            String   @id @default(cuid())
  buyerId       String
  sellerId      String
  productId     String?
  isOnline      Boolean  @default(false)
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  buyer   User     @relation("ThreadsBuyer", fields: [buyerId], references: [id])
  seller  User     @relation("ThreadsSeller", fields: [sellerId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  messages Message[]

  @@unique([buyerId, sellerId, productId])
  @@index([buyerId])
  @@index([sellerId])
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  senderId  String
  text      String   @default("")
  mediaUrl  String?
  mediaType String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  thread MessageThread @relation(fields: [threadId], references: [id])
  sender User          @relation(fields: [senderId], references: [id])

  @@index([threadId])
}

// ─── Favorite ─────────────────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

// ─── Order ────────────────────────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  buyerId         String
  sellerId        String?
  productId       String
  status          OrderStatus @default(PENDING)
  amount          Decimal     @db.Decimal(10, 2)
  protectionFee   Decimal     @db.Decimal(10, 2)
  shippingFee     Decimal     @db.Decimal(10, 2)
  shippingMethod  String?
  shippingAddress Json?
  stripePaymentId String?
  stripeSessionId String?
  threeDSecure    Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  buyer   User    @relation("OrderBuyer", fields: [buyerId], references: [id])
  seller  User?   @relation("OrderSeller", fields: [sellerId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  payout  SellerPayout?

  @@index([buyerId])
  @@index([sellerId])
  @@index([productId])
}

// ─── Review ───────────────────────────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  authorId  String
  targetId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  authorUser User @relation("ReviewAuthor", fields: [authorId], references: [id])
  targetUser User @relation("ReviewTarget", fields: [targetId], references: [id])

  @@unique([authorId, targetId])
  @@index([targetId])
}

// ─── Vote ─────────────────────────────────────────────────────────────────────

model Vote {
  id        String    @id @default(cuid())
  userId    String
  productId String
  value     VoteValue
  createdAt DateTime  @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@index([productId])
}

// ─── Report ───────────────────────────────────────────────────────────────────

model Report {
  id        String       @id @default(cuid())
  authorId  String
  productId String
  reason    ReportReason
  details   String?
  status    ReportStatus @default(PENDING)
  createdAt DateTime     @default(now())

  author  User    @relation("ReportAuthor", fields: [authorId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([authorId, productId])
  @@index([productId])
  @@index([status])
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

// ─── Sanction ─────────────────────────────────────────────────────────────────

model Sanction {
  id       String       @id @default(cuid())
  userId   String
  adminId  String
  type     SanctionType
  reason   String
  notes    String?
  startsAt DateTime     @default(now())
  endsAt   DateTime?
  createdAt DateTime    @default(now())

  user  User @relation("SanctionTarget", fields: [userId], references: [id])
  admin User @relation("SanctionAdmin", fields: [adminId], references: [id])

  @@index([userId])
}

// ─── Ban ──────────────────────────────────────────────────────────────────────

model Ban {
  id          String   @id @default(cuid())
  userId      String
  adminId     String
  reason      String
  isPermanent Boolean  @default(false)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  user  User @relation("BanTarget", fields: [userId], references: [id])
  admin User @relation("BanAdmin", fields: [adminId], references: [id])

  @@index([userId])
}

// ─── SellerPayout ─────────────────────────────────────────────────────────────

model SellerPayout {
  id          String       @id @default(cuid())
  sellerId    String
  orderId     String       @unique
  productId   String
  grossAmount Decimal      @db.Decimal(10, 2)
  platformFee Decimal      @db.Decimal(10, 2)
  shippingFee Decimal      @db.Decimal(10, 2)
  netAmount   Decimal      @db.Decimal(10, 2)
  status      PayoutStatus @default(PENDING)
  paidAt      DateTime?
  createdAt   DateTime     @default(now())

  seller  User    @relation(fields: [sellerId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([sellerId])
  @@index([status])
}
